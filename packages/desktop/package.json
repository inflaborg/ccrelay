{
  "name": "ccrelay-desktop",
  "version": "0.2.0",
  "private": true,
  "description": "CCRelay desktop tray app",
  "license": "MIT",
  "main": "out/main.js",
  "scripts": {
    "compile": "tsc --noEmit -p tsconfig.json",
    "build": "node ../../scripts/esbuild.desktop.mjs",
    "start": "electron .",
    "pack": "electron-builder",
    "pack:mac": "electron-builder --mac",
    "pack:mac:all": "electron-builder --mac --x64 --arm64",
    "pack:win": "electron-builder --win",
    "pack:win:all": "electron-builder --win --x64 --arm64"
  },
  "dependencies": {
    "@ccrelay/core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.0.4"
  },
  "build": {
    "appId": "com.inflab.ccrelay",
    "productName": "CCRelay",
    "artifactName": "${productName}-${version}-${platform}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "web",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets/tray-icon-template.png",
        "to": "assets/tray-icon-template.png"
      },
      {
        "from": "assets/tray-icon.png",
        "to": "assets/tray-icon.png"
      }
    ],
    "asarUnpack": [
      "out/database-worker.cjs"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "buildUniversalInstaller": false
    }
  }
}
