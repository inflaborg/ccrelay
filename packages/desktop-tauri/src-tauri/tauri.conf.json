{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCRelay",
  "version": "0.2.2",
  "identifier": "org.inflab.ccrelay",
  "build": {
    "frontendDist": "../web",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ccrelay-server"],
    "resources": [
      "../web/**/*",
      "../out/database-worker.cjs"
    ],
    "windows": {
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
